{
    "manifest_version": 3,
    "name": "NothingHome",
    "version": "1.0.2",
    "description": "Nothing-style New Tab Page",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": [
        "storage",
        "topSites",
        "geolocation",
        "favicon",
        "system.cpu",
        "system.memory",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "https://api.open-meteo.com/*"
    ],
    "action": {
        "default_title": "NothingHome",
        "default_icon": "icon_128.png"
    },
    "icons": {
        "16": "icon_16.png",
        "48": "icon_48.png",
        "128": "icon_128.png"
    }
}